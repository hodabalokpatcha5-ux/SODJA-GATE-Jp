# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Base de données (SQLite par défaut, PostgreSQL/Supabase si DATABASE_URL est défini)
DATABASE_URL=

# JWT_SECRET: Secret key for signing JSON Web Tokens.
JWT_SECRET="sodja-gate-secret-key-change-me"

# SMTP Configuration (For real email sending via Gmail)
# To get a password, go to Google Account > Security > 2-Step Verification > App Passwords
SMTP_USER="votre-email@gmail.com"
SMTP_PASS="votre-mot-de-passe-d-application"
SMTP_PORT="587"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# EmailJS Configuration (Frontend Email Sending)
VITE_EMAILJS_SERVICE_ID="votre_service_id"
VITE_EMAILJS_TEMPLATE_ID="template_6khkina"
VITE_EMAILJS_OTP_TEMPLATE_ID="votre_template_id_otp"
VITE_EMAILJS_PUBLIC_KEY="votre_cle_publique"

# Admin Configuration
VITE_ADMIN_EMAIL="sodjagatecommande@gmail.com"
